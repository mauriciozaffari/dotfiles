# Secrets - Copy this file to ~/.secrets and fill in your values
# This file is sourced by .zshrc at shell startup
#
# NEVER commit the actual ~/.secrets file to version control

# API Keys
# export OPENAI_API_KEY=""
# export ANTHROPIC_API_KEY=""

# Cloud Providers
# export AWS_ACCESS_KEY_ID=""
# export AWS_SECRET_ACCESS_KEY=""
# export AWS_DEFAULT_REGION="us-east-1"

# Docker Registry
# export DOCKER_USERNAME=""
# export DOCKER_PASSWORD=""

# Database
# export DATABASE_URL=""

# SSH Hosts (override defaults from ssh/config)
# export SSH_SERVER_HOST="192.168.1.253"
# export SSH_PC_HOST="yourhost.ddnsfree.com"
# export SSH_PC_PORT="2100"
